# PostgreSQL
POSTGRES_USER=observa
POSTGRES_PASSWORD=   # REQUIRED — change this before starting
POSTGRES_DB=inaturalist

# PostgREST API user (read-only, least-privilege)
API_USER_PASSWORD=   # REQUIRED — change this before starting

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=   # REQUIRED — change this before starting

# Alerting (optional — leave blank to disable Slack notifications)
SLACK_WEBHOOK_URL=

# Importer schedule (cron expression)
IMPORT_CRON=0 3 * * *

# Maximum allowed row count drop percentage before aborting import (default: 50%)
ROW_DROP_THRESHOLD=50

# Backup schedule (cron expression, default: weekly Sunday 2 AM)
BACKUP_CRON=0 2 * * 0

# Backup retention (number of backups to keep)
BACKUP_RETENTION=4
