{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Observers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Observers\" FROM mv_top_observers;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 2,
      "title": "Total Observations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT sum(observation_count) AS \"Observations\" FROM mv_top_observers;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 3,
      "title": "Avg Observations per Observer",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT round(avg(observation_count), 1) AS \"Average\" FROM mv_top_observers;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 4,
      "title": "Median Observations per Observer",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT percentile_cont(0.5) WITHIN GROUP (ORDER BY observation_count)::bigint AS \"Median\" FROM mv_top_observers;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 5,
      "title": "New Observers Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "WITH first_obs AS (SELECT observer_id, date_trunc('month', min(observed_on)) AS first_month FROM observations WHERE observed_on IS NOT NULL GROUP BY observer_id) SELECT first_month AS time, count(*) AS new_observers, sum(count(*)) OVER (ORDER BY first_month) AS cumulative_observers FROM first_obs WHERE first_month IS NOT NULL AND $__timeFilter(first_month) GROUP BY first_month ORDER BY first_month;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "title": "Top 30 Observers",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(login, 'observer_' || observer_id) AS observer, observation_count AS observations FROM mv_top_observers ORDER BY observation_count DESC LIMIT 30;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 7,
      "title": "Observer Activity Distribution",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN observation_count = 1 THEN '1' WHEN observation_count BETWEEN 2 AND 10 THEN '2-10' WHEN observation_count BETWEEN 11 AND 100 THEN '11-100' WHEN observation_count BETWEEN 101 AND 1000 THEN '101-1K' WHEN observation_count BETWEEN 1001 AND 10000 THEN '1K-10K' ELSE '10K+' END AS bucket, count(*) AS observers FROM mv_top_observers GROUP BY CASE WHEN observation_count = 1 THEN 1 WHEN observation_count BETWEEN 2 AND 10 THEN 2 WHEN observation_count BETWEEN 11 AND 100 THEN 3 WHEN observation_count BETWEEN 101 AND 1000 THEN 4 WHEN observation_count BETWEEN 1001 AND 10000 THEN 5 ELSE 6 END, bucket ORDER BY CASE WHEN observation_count = 1 THEN 1 WHEN observation_count BETWEEN 2 AND 10 THEN 2 WHEN observation_count BETWEEN 11 AND 100 THEN 3 WHEN observation_count BETWEEN 101 AND 1000 THEN 4 WHEN observation_count BETWEEN 1001 AND 10000 THEN 5 ELSE 6 END;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "vertical" }
    },
    {
      "id": 8,
      "title": "Top Observers — Detail",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT ob.login, ob.name, count(*) AS observations, count(DISTINCT o.taxon_id) AS species, count(DISTINCT p.photo_id) AS photos, min(o.observed_on) AS first_observation, max(o.observed_on) AS latest_observation FROM observations o JOIN observers ob ON o.observer_id = ob.observer_id LEFT JOIN photos p ON o.observation_uuid = p.observation_uuid GROUP BY ob.login, ob.name ORDER BY observations DESC LIMIT 50;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "id": 9,
      "title": "Species Diversity vs Observation Count",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(ob.login, 'observer_' || ob.observer_id) AS observer, count(DISTINCT o.taxon_id) AS species FROM observations o JOIN observers ob ON o.observer_id = ob.observer_id GROUP BY ob.login, ob.observer_id ORDER BY species DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 10,
      "title": "Monthly Active Observers",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('month', observed_on) AS time, count(DISTINCT observer_id) AS active_observers FROM observations WHERE observed_on IS NOT NULL AND $__timeFilter(observed_on) GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["inaturalist", "observa", "observers"],
  "templating": { "list": [] },
  "time": { "from": "now-5y", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Observer Activity",
  "uid": "observer-activity",
  "version": 1
}
