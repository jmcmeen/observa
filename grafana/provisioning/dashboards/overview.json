{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Observations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Observations\" FROM observations WHERE ('${quality_grade}' = '$__all' OR quality_grade IN (${quality_grade:sqlstring}));",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 2,
      "title": "Total Photos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Photos\" FROM photos;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 3,
      "title": "Total Taxa",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Taxa\" FROM taxa;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 4,
      "title": "Total Observers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Observers\" FROM observers;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 5,
      "title": "Last Import",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT finished_at AS \"Completed\", status AS \"Status\", observations_count AS \"Observations\", photos_count AS \"Photos\", taxa_count AS \"Taxa\", observers_count AS \"Observers\", duration_seconds || 's' AS \"Duration\" FROM import_log ORDER BY id DESC LIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 6,
      "title": "Observations Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT month AS time, observation_count AS observations FROM mv_observations_monthly WHERE $__timeFilter(month) ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 7,
      "title": "Top 20 Most Observed Taxa",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT name AS taxon, observation_count AS observations FROM mv_top_taxa WHERE ('${taxonomic_rank}' = '$__all' OR rank = '${taxonomic_rank}') ORDER BY observation_count DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0 }
    },
    {
      "id": 8,
      "title": "Quality Grade Distribution",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT quality_grade AS grade, total FROM mv_quality_grade_counts ORDER BY total DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut" }
    },
    {
      "id": 9,
      "title": "Photo License Distribution",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT license, total FROM mv_photo_licenses ORDER BY total DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut" }
    },
    {
      "id": 10,
      "title": "Observations by Taxonomic Rank",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT rank, observation_count AS observations FROM mv_observations_by_rank ORDER BY observation_count DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 11,
      "title": "Top 20 Observers",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT login, name, observation_count AS observations FROM mv_top_observers ORDER BY observation_count DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "id": 12,
      "title": "Observation Density Map",
      "type": "geomap",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT ST_Y(grid_geom) AS latitude, ST_X(grid_geom) AS longitude, observation_count AS metric FROM mv_observations_grid ORDER BY observation_count DESC LIMIT 5000;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "view": { "id": "fit", "lat": 0, "lon": 0, "zoom": 2 },
        "basemap": { "type": "default", "name": "OpenStreetMap" },
        "layers": [
          {
            "type": "heatmap",
            "name": "Observations",
            "config": {
              "weight": { "field": "metric", "fixed": 1 },
              "radius": { "fixed": 20 },
              "blur": { "fixed": 15 },
              "opacity": 0.6
            },
            "location": { "mode": "coords", "latitude": "latitude", "longitude": "longitude" }
          }
        ]
      }
    },
    {
      "id": 13,
      "title": "Research Grade Percentage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 46 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT round(100.0 * sum(CASE WHEN quality_grade = 'research' THEN total ELSE 0 END) / NULLIF(sum(total), 0), 1) AS \"Research Grade %\" FROM mv_quality_grade_counts;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 50 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 14,
      "title": "Photo Coverage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 46 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT round(100.0 * (SELECT count(DISTINCT observation_uuid) FROM photos) / NULLIF((SELECT count(*) FROM observations), 0), 1) AS \"With Photos %\";",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "green", "value": 70 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 15,
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 46 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT pg_size_pretty(pg_database_size(current_database())) AS \"DB Size\";",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 16,
      "title": "Seasonal Patterns (Observations by Month of Year)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT to_char(to_date(EXTRACT(MONTH FROM month)::text, 'MM'), 'Mon') AS month_name, sum(observation_count) AS observations FROM mv_observations_monthly WHERE $__timeFilter(month) GROUP BY EXTRACT(MONTH FROM month), month_name ORDER BY EXTRACT(MONTH FROM month);",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "vertical" }
    },
    {
      "id": 17,
      "title": "Cumulative Species Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "WITH monthly_new AS (SELECT date_trunc('month', min(observed_on)) AS first_month FROM observations WHERE taxon_id IS NOT NULL GROUP BY taxon_id) SELECT first_month AS time, sum(count(*)) OVER (ORDER BY first_month) AS cumulative_species FROM monthly_new WHERE first_month IS NOT NULL AND $__timeFilter(first_month) GROUP BY first_month ORDER BY first_month;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["inaturalist", "observa"],
  "templating": {
    "list": [
      {
        "name": "quality_grade",
        "label": "Quality Grade",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "inaturalist" },
        "query": "SELECT DISTINCT quality_grade FROM observations WHERE quality_grade IS NOT NULL ORDER BY quality_grade;",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1
      },
      {
        "name": "taxonomic_rank",
        "label": "Taxonomic Rank",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "inaturalist" },
        "query": "SELECT DISTINCT rank FROM taxa WHERE rank IS NOT NULL ORDER BY rank_level;",
        "multi": false,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-5y", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "iNaturalist Overview",
  "uid": "inaturalist-overview",
  "version": 2
}
