{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Observations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Observations\" FROM observations;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 2,
      "title": "Total Photos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Photos\" FROM photos;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 3,
      "title": "Total Taxa",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Taxa\" FROM taxa;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 4,
      "title": "Total Observers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Observers\" FROM observers;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 5,
      "title": "Last Import",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT finished_at AS \"Completed\", status AS \"Status\", observations_count AS \"Observations\", photos_count AS \"Photos\", taxa_count AS \"Taxa\", observers_count AS \"Observers\" FROM import_log ORDER BY id DESC LIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 6,
      "title": "Observations Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('month', observed_on) AS time, count(*) AS observations FROM observations WHERE observed_on IS NOT NULL GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 7,
      "title": "Top 20 Most Observed Taxa",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT t.name AS taxon, count(*) AS observations FROM observations o JOIN taxa t ON o.taxon_id = t.taxon_id WHERE t.rank = 'species' GROUP BY t.name ORDER BY observations DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0 }
    },
    {
      "id": 8,
      "title": "Quality Grade Distribution",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT quality_grade AS grade, count(*) AS total FROM observations WHERE quality_grade IS NOT NULL GROUP BY quality_grade ORDER BY total DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut" }
    },
    {
      "id": 9,
      "title": "Photo License Distribution",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT license, count(*) AS total FROM photos WHERE license IS NOT NULL GROUP BY license ORDER BY total DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut" }
    },
    {
      "id": 10,
      "title": "Observations by Taxonomic Rank",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT t.rank, count(*) AS observations FROM observations o JOIN taxa t ON o.taxon_id = t.taxon_id WHERE t.rank IS NOT NULL GROUP BY t.rank ORDER BY observations DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 11,
      "title": "Top 20 Observers",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT ob.login, ob.name, count(*) AS observations FROM observations o JOIN observers ob ON o.observer_id = ob.observer_id GROUP BY ob.login, ob.name ORDER BY observations DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    }
  ],
  "schemaVersion": 39,
  "tags": ["inaturalist", "observa"],
  "templating": { "list": [] },
  "time": { "from": "now-5y", "to": "now" },
  "timepicker": {},
