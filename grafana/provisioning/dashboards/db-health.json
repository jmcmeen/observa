{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Cache Hit Ratio",
      "description": "Percentage of reads served from shared buffers vs disk. Should be >99% for a warm database.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT round(100.0 * sum(blks_hit) / NULLIF(sum(blks_hit) + sum(blks_read), 0), 2) AS \"Cache Hit %\" FROM pg_stat_database WHERE datname = current_database();",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Index Hit Ratio",
      "description": "Percentage of index reads served from cache. Low values indicate missing or cold indexes.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT round(100.0 * sum(idx_blks_hit) / NULLIF(sum(idx_blks_hit) + sum(idx_blks_read), 0), 2) AS \"Index Hit %\" FROM pg_statio_user_indexes;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT pg_size_pretty(pg_database_size(current_database())) AS \"Size\";",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 4,
      "title": "Active Queries",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT pid, usename AS \"User\", state, left(query, 120) AS \"Query\", now() - query_start AS \"Duration\", wait_event_type AS \"Wait\" FROM pg_stat_activity WHERE state != 'idle' AND pid != pg_backend_pid() ORDER BY query_start;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Duration", "desc": true }] }
    },
    {
      "id": 5,
      "title": "Table Sizes",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT relname AS \"Table\", pg_total_relation_size(c.oid) / 1024 / 1024 AS \"Size (MB)\" FROM pg_class c JOIN pg_namespace n ON n.oid = c.relnamespace WHERE n.nspname = 'public' AND c.relkind IN ('r', 'm') ORDER BY pg_total_relation_size(c.oid) DESC LIMIT 15;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "xField": "Table", "orientation": "horizontal" }
    },
    {
      "id": 6,
      "title": "Index Usage",
      "description": "Tables with low index scan ratios may benefit from additional indexes.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT relname AS \"Table\", seq_scan AS \"Seq Scans\", idx_scan AS \"Index Scans\", CASE WHEN seq_scan + idx_scan > 0 THEN round(100.0 * idx_scan / (seq_scan + idx_scan), 1) ELSE 0 END AS \"Index %\", n_live_tup AS \"Live Rows\" FROM pg_stat_user_tables ORDER BY seq_scan DESC LIMIT 15;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Seq Scans", "desc": true }] }
    },
    {
      "id": 7,
      "title": "Table Bloat Estimate",
      "description": "Ratio of dead tuples to live tuples. High values indicate the table needs VACUUM.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT relname AS \"Table\", n_live_tup AS \"Live Rows\", n_dead_tup AS \"Dead Rows\", CASE WHEN n_live_tup > 0 THEN round(100.0 * n_dead_tup / n_live_tup, 1) ELSE 0 END AS \"Bloat %\", last_vacuum AS \"Last Vacuum\", last_autovacuum AS \"Last Autovacuum\" FROM pg_stat_user_tables WHERE n_live_tup > 0 ORDER BY n_dead_tup DESC LIMIT 15;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Dead Rows", "desc": true }] }
    },
    {
      "id": 8,
      "title": "Slowest Queries (pg_stat_statements)",
      "description": "Top queries by mean execution time. Requires pg_stat_statements extension.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT calls AS \"Calls\", round(mean_exec_time::numeric, 1) AS \"Mean (ms)\", round(total_exec_time::numeric / 1000, 1) AS \"Total (s)\", rows AS \"Rows\", left(query, 100) AS \"Query\" FROM pg_stat_statements WHERE dbid = (SELECT oid FROM pg_database WHERE datname = current_database()) ORDER BY mean_exec_time DESC LIMIT 15;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Mean (ms)", "desc": true }] }
    },
    {
      "id": 9,
      "title": "Connection Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS \"Active\" FROM pg_stat_activity WHERE state = 'active' AND pid != pg_backend_pid();",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 10,
      "title": "Transaction Throughput",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 30 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT xact_commit + xact_rollback AS \"Total Transactions\" FROM pg_stat_database WHERE datname = current_database();",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 11,
      "title": "Temp Files Created",
      "description": "Queries that spill to disk due to insufficient work_mem. High values suggest increasing work_mem.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 30 },
      "datasource": { "type": "postgres", "uid": "inaturalist" },
      "targets": [
        {
          "rawSql": "SELECT temp_files AS \"Temp Files\", pg_size_pretty(temp_bytes) AS \"Temp Size\" FROM pg_stat_database WHERE datname = current_database();",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["database", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Database Health",
  "uid": "db-health"
}
